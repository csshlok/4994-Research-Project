{
  "N_reviews": 9848,
  "companies": 10,
  "goals": [
    "phys",
    "selfprot",
    "aff",
    "stat",
    "fam"
  ],
  "columns_review": [
    "review_id",
    "company_id",
    "date",
    "n_tokens",
    "S_raw",
    "F_raw_phys",
    "H_raw_phys",
    "G_ratio_phys",
    "w_sent_phys",
    "G_final_phys",
    "F_raw_selfprot",
    "H_raw_selfprot",
    "G_ratio_selfprot",
    "w_sent_selfprot",
    "G_final_selfprot",
    "F_raw_aff",
    "H_raw_aff",
    "G_ratio_aff",
    "w_sent_aff",
    "G_final_aff",
    "F_raw_stat",
    "H_raw_stat",
    "G_ratio_stat",
    "w_sent_stat",
    "G_final_stat",
    "F_raw_fam",
    "H_raw_fam",
    "G_ratio_fam",
    "w_sent_fam",
    "G_final_fam"
  ],
  "columns_company": [
    "company_id",
    "n_reviews",
    "S_mean",
    "S_std",
    "S_smoothed",
    "SE",
    "S_CI_low",
    "S_CI_high",
    "pos_share",
    "neg_share",
    "G_mean_ratio_phys",
    "G_mean_final_phys",
    "G_smoothed_final_phys",
    "G_mean_ratio_selfprot",
    "G_mean_final_selfprot",
    "G_smoothed_final_selfprot",
    "G_mean_ratio_aff",
    "G_mean_final_aff",
    "G_smoothed_final_aff",
    "G_mean_ratio_stat",
    "G_mean_final_stat",
    "G_smoothed_final_stat",
    "G_mean_ratio_fam",
    "G_mean_final_fam",
    "G_smoothed_final_fam"
  ],
  "run_meta": {
    "model": "cardiffnlp/twitter-roberta-base-sentiment-latest",
    "batch": 48,
    "max_length": 256,
    "lexicon_match_weights": {
      "w_uni": 1.0,
      "w_bi": 1.25,
      "w_long": 2.0
    },
    "ratio_formula": "(F - H) / (F + H + eps)",
    "sentiment_weighting": {
      "eps": 0.08,
      "tau": 0.5,
      "lo": 0.3,
      "hi": 1.2
    },
    "offline_model": false,
    "env": {
      "python": "3.13.5",
      "torch": "2.7.1+cu118",
      "numpy": "2.3.0"
    },
    "output_files": {
      "review_csv": "/out/review_scores.csv",
      "company_csv": "/out/company_scores.csv",
      "per_company_dir": "/out/per_company",
      "per_company_files_count": 10,
      "per_company_cols": [
        "review_id",
        "company_id",
        "S_raw",
        "G_ratio_phys",
        "G_final_phys",
        "G_ratio_selfprot",
        "G_final_selfprot",
        "G_ratio_aff",
        "G_final_aff",
        "G_ratio_stat",
        "G_final_stat",
        "G_ratio_fam",
        "G_final_fam"
      ]
    }
  }
}
